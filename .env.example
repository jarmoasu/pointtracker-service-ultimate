# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# --- Database ---
# For local development with Prisma Postgres (run `prisma dev` to start a local instance).
# The key below is generated by `prisma dev`; replace it with the one shown in your terminal.
# DATABASE_URL="prisma+postgres://localhost:51213/?api_key=<key-from-prisma-dev-output>"
#
# For production (Render / any host), use a standard PostgreSQL URL or
# a remote Prisma Postgres URL from your Prisma Data Platform dashboard:
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- Auth ---
# Admin login password (stored hashed; plain text only used on first boot)
ADMIN_PASSWORD=change-me-before-deploying

# Claim code that writer-role users enter to register
CLAIM_CODE=your-claim-code-here

# 64-character hex string used to sign session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET_HEX=replace-with-output-of-openssl-rand-hex-32

# --- Optional ---
# Logical name for this deployment's data stream (default: main)
# STREAM_ID=main

# Port the server listens on (Render injects this automatically in production)
# PORT=3000
