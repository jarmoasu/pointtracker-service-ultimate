// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}
model StreamState {
  streamId             String   @id
  label                String   @default("")
  homeTeamName         String   @default("")
  awayTeamName         String   @default("")
  homeScore            Int      @default(0)
  awayScore            Int      @default(0)
  gameClockSeconds     Int      @default(0)
  clockRunning         Boolean  @default(false)
  clockStartedAt       DateTime?

  // Timeout/halftime break, tracked independently of the main game clock
  // (which never pauses for these). Count-up only — no configured duration
  // or which-team info is stored server-side.
  breakActive          Boolean  @default(false)
  breakType            String?  // "timeout" | "halftime"
  breakStartedAt       DateTime?

  lastScoreTeam        String?  // "home" | "away"
  lastScorer           String?
  lastAssist           String?
  lastScoreClockSeconds Int?

  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())
}

// One row per court/game. Replaces the old single AuthState singleton so
// several games can be claimed/written independently on one backend.
model StreamAuth {
  streamId             String   @id
  claimCodeHash        String
  claimCodePlaintext   String?
  activeWriteTokenHash String?
  activeWriterName     String?
  claimedAt            DateTime?
  lastRequestId        String?

  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())
}

model AdminAuth {
  id                  Int      @id @default(1)
  adminPasswordHash   String
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}
